# MCP Helm Server Configuration Example
# Copy this file to .env and configure for your environment

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# ============================================
# Kubernetes Configuration
# ============================================
# Path to kubeconfig file (leave empty for in-cluster config)
KUBECONFIG=~/.kube/config

# Use in-cluster configuration (set to true when running in k8s)
IN_CLUSTER=false

# Kubernetes context to use (optional)
KUBE_CONTEXT=

# Default namespace
KUBE_NAMESPACE=default

# ============================================
# Helm Configuration
# ============================================
# Helm storage driver (secret, configmap, memory)
HELM_DRIVER=secret

# Maximum number of revisions to keep
HELM_MAX_HISTORY=10

# ============================================
# Logging Configuration
# ============================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=json

# ============================================
# MCP Configuration
# ============================================
# MCP transport: stdio, http
MCP_TRANSPORT=stdio

# MCP HTTP port (only used when MCP_TRANSPORT=http)
MCP_PORT=9090